<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Connexion</title>
</head>
<body>
  <h2>Connexion</h2>

  <input type="text" id="id" placeholder="Identifiant"><br><br>
  <input type="password" id="mdp" placeholder="Mot de passe"><br><br>

  <button onclick="connexion()">Se connecter</button>

  <script>
    function connexion() {
      const identifiant = document.getElementById("id").value;
      const motdepasse = document.getElementById("mdp").value;

      document.body.innerHTML = `
        <h2>Résultat</h2>
        <p><strong>Identifiant :</strong> ${identifiant}</p>
        <p><strong>Mot de passe :</strong> ${motdepasse}</p>
      `;
    }
  </script>
</body>
</html>
